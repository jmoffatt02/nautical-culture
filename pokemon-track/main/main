              WIN
            </button>
            <button className="result-btn loss" onClick={() => addMatch('L')}>
              LOSS
            </button>
          </div>
          <div className="keyboard-hint">
            type opponent name, then click W/L or hit <kbd>enter</kbd> for win, <kbd>shift+enter</kbd> for loss
          </div>
          {knownOpponents.length > 0 && (
            <div className="quick-chips">
              {knownOpponents.slice(0, 6).map(o => (
                <button key={o} className="chip" onClick={() => {
                  setOpponent(o)
                  inputRef.current?.focus()
                }}>
                  {o}
                </button>
              ))}
            </div>
          )}
        </div>

        {/* STATS CARDS */}
        {stats.total > 0 && (
          <div className="stats-grid">
            <div className="stat-card">
              <div className="stat-label">win rate</div>
              <div className="stat-value accent">{stats.winRate.toFixed(1)}%</div>
              <div className="stat-meta">across {stats.total} games</div>
            </div>
            <div className="stat-card">
              <div className="stat-label">wins</div>
              <div className="stat-value win">{stats.wins}</div>
              <div className="stat-meta">total</div>
            </div>
            <div className="stat-card">
              <div className="stat-label">losses</div>
              <div className="stat-value loss">{stats.losses}</div>
              <div className="stat-meta">total</div>
            </div>
            <div className="stat-card">
              <div className="stat-label">current streak</div>
              <div className={`stat-value ${stats.streakType === 'W' ? 'win' : 'loss'}`}>
                {stats.streak}{stats.streakType}
              </div>
              <div className="stat-meta">{stats.streakType === 'W' ? 'on a roll' : 'shake it off'}</div>
            </div>
          </div>
        )}

        {/* OPPONENT BREAKDOWN */}
        {stats.opponents.length > 0 && (
          <div className="section">
            <div className="section-header">
              <h2 className="section-title">matchup breakdown</h2>
              <div className="opp-controls">
                <input
                  className="filter-input"
                  placeholder="filter pokemon..."
                  value={filterText}
                  onChange={(e) => setFilterText(e.target.value)}
                />
                <select
                  className="sort-select"
                  value={sortBy}
                  onChange={(e) => setSortBy(e.target.value)}
                >
                  <option value="played">sort: played</option>
                  <option value="winrate">sort: win %</option>
                  <option value="wins">sort: wins</option>
                  <option value="losses">sort: losses</option>
                  <option value="name">sort: name</option>
                </select>
              </div>
            </div>
            <table className="opp-table">
              <thead>
                <tr>
                  <th>opponent</th>
                  <th className="num">played</th>
                  <th className="num">w</th>
                  <th className="num">l</th>
                  <th className="num">win rate</th>
                </tr>
              </thead>
              <tbody>
                {sortedOpponents.map(o => {
                  const wrClass = o.winRate >= 60 ? 'wr-good' : o.winRate < 40 ? 'wr-bad' : 'wr-mid'
                  return (
                    <tr key={o.name}>
                      <td className="opp-name">{o.name}</td>
                      <td className="num">{o.played}</td>
                      <td className="num" style={{color: 'var(--win)'}}>{o.wins}</td>
                      <td className="num" style={{color: 'var(--loss)'}}>{o.losses}</td>
                      <td className="num">
                        <div className="winrate-cell">
                          <div className="winrate-bar">
                            <div
                              className="winrate-fill"
                              style={{
                                width: `${o.winRate}%`,
                                background: o.winRate >= 50 ? 'var(--win)' : 'var(--loss)'
                              }}
                            />
                          </div>
                          <span className={`winrate-text ${wrClass}`}>
                            {o.winRate.toFixed(0)}%
                          </span>
                        </div>
                      </td>
                    </tr>
                  )
                })}
              </tbody>
            </table>
          </div>
        )}

        {/* RECENT MATCHES */}
        {recentMatches.length > 0 && (
          <div className="section">
            <div className="section-header">
              <h2 className="section-title">recent matches</h2>
              <span style={{color: 'var(--text-dim)', fontFamily: 'JetBrains Mono, monospace', fontSize: '0.75rem'}}>
                showing {recentMatches.length} of {matches.length}
              </span>
            </div>
            <div className="recent-list">
              {recentMatches.map(m => {
                const d = new Date(m.date)
                const dateStr = d.toLocaleDateString(undefined, {
                  month: 'short', day: 'numeric'
                }) + ' · ' + d.toLocaleTimeString(undefined, {
                  hour: '2-digit', minute: '2-digit'
                })
                return (
                  <div
                    key={m.id}
                    className={`recent-item ${flashId === m.id ? 'flash' : ''} ${m.result === 'L' ? 'l' : ''}`}
                  >
                    <div className={`result-tag ${m.result}`}>{m.result}</div>
                    <div className="recent-name">{m.opponent}</div>
                    <div className="recent-date">{dateStr}</div>
                    <button
                      className="delete-btn"
                      onClick={() => deleteMatch(m.id)}
                      title="delete this match"
                    >
                      ×
                    </button>
                  </div>
                )
              })}
            </div>
          </div>
        )}

        {/* EMPTY STATE */}
        {stats.total === 0 && (
          <div className="empty-state">
            no matches logged yet. add one above or import your existing data ↓
          </div>
        )}

        {/* TOOLS */}
        <div className="tools-bar">
          <button className="tool-btn" onClick={() => setShowImport(!showImport)}>
            {showImport ? '× cancel import' : '+ import data'}
          </button>
          {matches.length > 0 && (
            <>
              <button className="tool-btn" onClick={downloadCsv}>
                ↓ export csv
              </button>
              {!confirmClear ? (
                <button className="tool-btn danger" onClick={() => setConfirmClear(true)}>
                  clear all data
                </button>
              ) : (
                <>
                  <span style={{
                    color: 'var(--loss)',
                    fontFamily: 'JetBrains Mono, monospace',
                    fontSize: '0.8rem',
                    alignSelf: 'center'
                  }}>
                    delete all {matches.length} matches?
                  </span>
                  <button className="tool-btn danger" onClick={clearAll}>
                    yes, delete
                  </button>
                  <button className="tool-btn" onClick={() => setConfirmClear(false)}>
                    cancel
                  </button>
                </>
              )}
            </>
          )}
        </div>

        {/* IMPORT PANEL */}
        {showImport && (
          <div className="import-panel">
            <h3>import from your sheet</h3>
            <p>
              paste rows from your google sheet below. supported formats (one per line):
              <br />
              <code>Pikachu, W</code> &nbsp; one match per row
              <br />
              <code>Pikachu, WLLWW</code> &nbsp; multiple matches in one row (W/L sequence)
              <br />
              <code>Pikachu, 5, 2</code> &nbsp; aggregate (name, wins, losses)
              <br />
              you can use commas <em>or</em> tabs as separators (tabs = direct paste from sheets).
            </p>
            <textarea
              className="import-textarea"
              placeholder={`Pikachu\tW\nCharizard\tL\nGarchomp\t3\t1`}
              value={importText}
              onChange={(e) => {
                setImportText(e.target.value)
                setImportPreview(null)
              }}
            />
            <div className="import-actions">
              <button className="tool-btn" onClick={previewImport} disabled={!importText.trim()}>
                preview
              </button>
              {importPreview && (
                <>
                  <span className="import-preview-info">
                    found {importPreview.length} matches
                  </span>
                  <button className="tool-btn" onClick={commitImport}>
                    ✓ add to tracker
                  </button>
                </>
              )}
            </div>
          </div>
        )}

      </div>
    </div>
  )
}
