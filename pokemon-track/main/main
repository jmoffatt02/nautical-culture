import { useState, useEffect, useMemo, useRef } from 'react'

// ---------- storage helpers ----------
const STORAGE_KEY = 'pokemon-matches'

async function loadMatches() {
  try {
    const result = await window.storage.get(STORAGE_KEY)
    if (!result) return []
    return JSON.parse(result.value)
  } catch (e) {
    return []
  }
}

async function saveMatches(matches) {
  try {
    await window.storage.set(STORAGE_KEY, JSON.stringify(matches))
  } catch (e) {
    console.error('save failed', e)
  }
}

// ---------- utils ----------
const uid = () => Math.random().toString(36).slice(2, 11)

const normalize = (s) => s.trim().toLowerCase()

const parseImportText = (text) => {
  const lines = text.split('\n').map(l => l.trim()).filter(Boolean)
  const matches = []
  const today = new Date().toISOString()

  for (const line of lines) {
    // split on comma OR tab
    const parts = line.split(/[,\t]/).map(p => p.trim()).filter(Boolean)
    if (parts.length < 2) continue

    const opponent = parts[0]

    // detect format: "name, W" or "name, L" or "name, W/L/W/L"
    if (parts.length === 2) {
      const r = parts[1].toUpperCase()
      // could be a single result or a string like "WLLWW"
      if (r === 'W' || r === 'WIN' || r === '1') {
        matches.push({ id: uid(), opponent, result: 'W', date: today })
      } else if (r === 'L' || r === 'LOSS' || r === 'LOSE' || r === '0') {
        matches.push({ id: uid(), opponent, result: 'L', date: today })
      } else if (/^[WL]+$/i.test(r)) {
        // string like "WWLW" - one match per char
        for (const ch of r) {
          matches.push({ id: uid(), opponent, result: ch.toUpperCase(), date: today })
        }
      }
    } else if (parts.length >= 3) {
      // "name, wins, losses" aggregate format
      const wins = parseInt(parts[1], 10)
      const losses = parseInt(parts[2], 10)
      if (!isNaN(wins) && !isNaN(losses)) {
        for (let i = 0; i < wins; i++) {
          matches.push({ id: uid(), opponent, result: 'W', date: today })
        }
        for (let i = 0; i < losses; i++) {
          matches.push({ id: uid(), opponent, result: 'L', date: today })
        }
      }
    }
  }
  return matches
}

const exportToCsv = (matches) => {
  const header = 'opponent,result,date\n'
  const rows = matches.map(m => `${m.opponent},${m.result},${m.date}`).join('\n')
  return header + rows
}

// ---------- main ----------
export default function PokemonTracker() {
  const [matches, setMatches] = useState([])
  const [loading, setLoading] = useState(true)
  const [opponent, setOpponent] = useState('')
  const [showImport, setShowImport] = useState(false)
  const [importText, setImportText] = useState('')
  const [importPreview, setImportPreview] = useState(null)
  const [sortBy, setSortBy] = useState('played')
  const [filterText, setFilterText] = useState('')
  const [confirmClear, setConfirmClear] = useState(false)
  const [flashId, setFlashId] = useState(null)
  const inputRef = useRef(null)

  // load on mount
  useEffect(() => {
    loadMatches().then(m => {
      setMatches(m)
      setLoading(false)
    })
  }, [])

  // persist whenever matches change (after initial load)
  useEffect(() => {
    if (!loading) saveMatches(matches)
  }, [matches, loading])

  // ---------- derived stats ----------
  const stats = useMemo(() => {
    const total = matches.length
    const wins = matches.filter(m => m.result === 'W').length
    const losses = total - wins
    const winRate = total > 0 ? (wins / total) * 100 : 0

    // per-opponent aggregation (case-insensitive)
    const byOpponent = {}
    for (const m of matches) {
      const key = normalize(m.opponent)
      if (!byOpponent[key]) {
        byOpponent[key] = { name: m.opponent, wins: 0, losses: 0, played: 0 }
      }
      byOpponent[key].played++
      if (m.result === 'W') byOpponent[key].wins++
      else byOpponent[key].losses++
    }
    const opponents = Object.values(byOpponent).map(o => ({
      ...o,
      winRate: o.played > 0 ? (o.wins / o.played) * 100 : 0
    }))

    // current streak (from most recent match backward)
    const sortedByDate = [...matches].sort((a, b) => new Date(b.date) - new Date(a.date))
    let streak = 0
    let streakType = null
    for (const m of sortedByDate) {
      if (streakType === null) {
        streakType = m.result
        streak = 1
      } else if (m.result === streakType) {
        streak++
      } else {
        break
      }
    }

    return { total, wins, losses, winRate, opponents, streak, streakType }
  }, [matches])

  const sortedOpponents = useMemo(() => {
    const filtered = stats.opponents.filter(o =>
      o.name.toLowerCase().includes(filterText.toLowerCase())
    )
    const sorted = [...filtered]
    sorted.sort((a, b) => {
      if (sortBy === 'name') return a.name.localeCompare(b.name)
      if (sortBy === 'winrate') return b.winRate - a.winRate
      if (sortBy === 'wins') return b.wins - a.wins
      if (sortBy === 'losses') return b.losses - a.losses
      return b.played - a.played // default: played
    })
    return sorted
  }, [stats.opponents, sortBy, filterText])

  const recentMatches = useMemo(() => {
    return [...matches]
      .sort((a, b) => new Date(b.date) - new Date(a.date))
      .slice(0, 12)
  }, [matches])

  // existing opponent names for autocomplete
  const knownOpponents = useMemo(() => {
    return [...new Set(matches.map(m => m.opponent))]
      .sort((a, b) => {
        const aCount = matches.filter(m => normalize(m.opponent) === normalize(a)).length
        const bCount = matches.filter(m => normalize(m.opponent) === normalize(b)).length
        return bCount - aCount
      })
  }, [matches])

  // ---------- handlers ----------
  const addMatch = (result) => {
    const name = opponent.trim()
    if (!name) {
      inputRef.current?.focus()
      return
    }
    // use canonical casing if opponent already exists
    const existing = matches.find(m => normalize(m.opponent) === normalize(name))
    const canonicalName = existing ? existing.opponent : name

    const newMatch = {
      id: uid(),
      opponent: canonicalName,
      result,
      date: new Date().toISOString()
    }
    setMatches(prev => [...prev, newMatch])
    setOpponent('')
    setFlashId(newMatch.id)
    setTimeout(() => setFlashId(null), 800)
    inputRef.current?.focus()
  }

  const deleteMatch = (id) => {
    setMatches(prev => prev.filter(m => m.id !== id))
  }

  const handleKey = (e) => {
    if (e.key === 'Enter') {
      // shift+enter = loss, plain enter = win
      addMatch(e.shiftKey ? 'L' : 'W')
    }
  }

  const previewImport = () => {
    const parsed = parseImportText(importText)
    setImportPreview(parsed)
  }

  const commitImport = () => {
    if (!importPreview) return
    setMatches(prev => [...prev, ...importPreview])
    setImportText('')
    setImportPreview(null)
    setShowImport(false)
  }

  const downloadCsv = () => {
    const csv = exportToCsv(matches)
    const blob = new Blob([csv], { type: 'text/csv' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = `pokemon-matches-${new Date().toISOString().slice(0,10)}.csv`
    a.click()
    URL.revokeObjectURL(url)
  }

  const clearAll = () => {
    setMatches([])
    setConfirmClear(false)
  }

  // ---------- render ----------
  if (loading) {
    return (
      <div style={{
        minHeight: '100vh',
        background: '#0a0a0f',
        color: '#71717a',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontFamily: 'JetBrains Mono, monospace'
      }}>
        loading matches...
      </div>
    )
  }

  return (
    <div className="tracker-root">
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=JetBrains+Mono:wght@400;600;800&family=Manrope:wght@400;500;700&display=swap');

        .tracker-root {
          --bg: #0a0a0f;
          --surface: #13131c;
          --surface-hover: #1a1a25;
          --border: #26262f;
          --border-strong: #3a3a48;
          --text: #f4f4f5;
          --text-muted: #71717a;
          --text-dim: #52525b;
          --win: #34d399;
          --win-glow: rgba(52, 211, 153, 0.15);
          --loss: #f87171;
          --loss-glow: rgba(248, 113, 113, 0.15);
          --accent: #fbbf24;

          min-height: 100vh;
          background: var(--bg);
          background-image:
            radial-gradient(circle at 20% 0%, rgba(251, 191, 36, 0.04) 0%, transparent 50%),
            radial-gradient(circle at 80% 100%, rgba(52, 211, 153, 0.03) 0%, transparent 50%);
          color: var(--text);
          font-family: 'Manrope', sans-serif;
          padding: 2.5rem 1.5rem 4rem;
        }

        .container {
          max-width: 1100px;
          margin: 0 auto;
        }

        /* HEADER */
        .header {
          display: flex;
          justify-content: space-between;
          align-items: flex-end;
          margin-bottom: 2.5rem;
          padding-bottom: 1.5rem;
          border-bottom: 1px solid var(--border);
          flex-wrap: wrap;
          gap: 1rem;
        }
        .title-block h1 {
          font-family: 'Bricolage Grotesque', sans-serif;
          font-weight: 800;
          font-size: clamp(1.8rem, 4vw, 2.8rem);
          letter-spacing: -0.03em;
          line-height: 1;
          margin: 0;
        }
        .title-block .subtitle {
          color: var(--text-dim);
          font-size: 0.85rem;
          margin-top: 0.4rem;
          font-family: 'JetBrains Mono', monospace;
          text-transform: uppercase;
          letter-spacing: 0.1em;
        }
        .accent-bar {
          display: inline-block;
          width: 0.8rem;
          height: 0.8rem;
          background: var(--accent);
          margin-right: 0.6rem;
          vertical-align: middle;
          transform: rotate(45deg);
        }
        .record-pill {
          font-family: 'JetBrains Mono', monospace;
          font-size: 1.1rem;
          font-weight: 600;
          padding: 0.6rem 1rem;
          background: var(--surface);
          border: 1px solid var(--border);
          display: flex;
          align-items: center;
          gap: 0.5rem;
        }
        .record-pill .w { color: var(--win); }
