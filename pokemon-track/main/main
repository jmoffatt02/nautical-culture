          padding: 0.45rem 0.8rem;
          font-size: 0.85rem;
          font-family: 'Manrope', sans-serif;
          outline: none;
          width: 180px;
        }
        .filter-input:focus { border-color: var(--accent); }
        .sort-select {
          background: var(--surface);
          border: 1px solid var(--border);
          color: var(--text);
          padding: 0.45rem 0.8rem;
